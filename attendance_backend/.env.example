# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/attendance_db

# JWT
SECRET_KEY=change-me-use-a-long-random-string-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# QR Code
QR_TOKEN_EXPIRE_SECONDS=300

# Docker Compose PostgreSQL (used by docker-compose.yml only)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=attendance_db


